{
  "manifest_version": 3,
  "name": "biliCostumize",
  "description": "Customize Bilibili with a minimal homepage and focus controls",
  "version": "1.0.0",
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "options_ui": {
    "page": "options.html"
  },
  "action": {
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    },
    "default_popup": "options.html"
  },
  "background": {
    "service_worker": "js/background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.bilibili.com/*"],
      "js": ["bilifocus_content.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["*://www.bilibili.com/*"],
      "css": ["css/content_style.css"],
      "js": ["js/content_script.js"]
    },
    {
      "matches": ["https://www.bilibili.com/video/*"],
      "css": ["css/video_content_style.css"],
      "js": ["js/video_content_script.js"]
    }
  ],
  "permissions": [
    "storage",
    "tabs"
  ]
}
